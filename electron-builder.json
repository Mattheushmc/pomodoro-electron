{
  "appId": "com.pomodoro.app",
  "productName": "Pomodoro-Electron",

  "asar": true,
  "compression": "store",

  "artifactName": "${productName}-${version}-${arch}.${ext}",

  "publish": [
    {
      "provider": "github"
    }
  ],

  "directories": {
    "output": "dist",
    "buildResources": "assets",
    "app": "."
  },

  "files": [
    "out/**/*",
    "package.json"
  ],

  "extraResources": [
    {
      "from": "assets/",
      "to": "assets",
      "filter": ["**/*"]
    }
  ],

  "mac": {
    "category": "public.app-category.productivity",
    "target": [
      { "target": "dmg", "arch": ["x64"] },
      { "target": "dmg", "arch": ["arm64"] },
      { "target": "dmg", "arch": ["universal"] }
    ]
  },

  "dmg": {
    "contents": [
      { "x": 130, "y": 220 },
      { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
    ]
  },

  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },

  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "allowToChangeInstallationDirectory": false
  },

  "linux": {
    "icon": "assets",
    "category": "Utility",
    "maintainer": "Luiz Henrique <luiz@example.com>",
    "target": ["AppImage", "deb"]
  }
}
